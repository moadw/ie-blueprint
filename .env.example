VITE_GRAPHQL_URL=https://api-test.blueprint.kids/graphql
VITE_REST_URL=https://api-test.blueprint.kids
# UUID real de la plataforma en api-test/api (el valor "innerexplorer" no existe en el backend y filtra todo a 0)
VITE_PLATFORM=31ee8812-e253-11ef-9cd2-0242ac120002
SESSION_SECRET=dev-secret-change-me
# Amplitude test-account API key. Optional locally — leave blank to disable analytics in dev.
VITE_AMPLITUDE_API_KEY=

# SSO — app origin used to build the OAuth redirect_uri (NO trailing slash).
# Constructed as ${VITE_APP_URL}/signup-clever etc. Local dev (Vite default port): http://localhost:5173;
# test/prod: e.g. https://app-test.innerexplorer.org. Must be a valid URL (or blank) or boot fails.
VITE_APP_URL=http://localhost:5173
# Clever / ClassLink OAuth client IDs (IE-owned apps — must be provisioned + redirect
# URIs registered; see plan appendix). Leave blank until supplied → button degrades to disabled.
VITE_CLEVER_CLIENT_ID=
VITE_CLASSLINK_CLIENT_ID=
# Firebase config for Google SSO (reuse Blueprint's project or an IE-owned one; see research doc).
# Leave blank until supplied → Google button degrades to disabled.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
